/**
 * dmenu-crystal — vim command-line style rofi
 * Sits in bottom bar center gap between left and right modules
 */

@import "~/.config/omarchy/current/theme/rofi.rasi"

* {
    background-color: #00000000;
    text-color:       #dcd7ba;
}

window {
    anchor:     south;
    location:   southeast;
    x-offset:   25;
    y-offset:   0;
    padding:    2;
    font-size:  10;
    children:   [ horibox ];
    border:     0;
    border-radius: 0;
    background-color: transparent;
}

horibox {
    orientation: horizontal;
    children:   [ prompt, entry ];
    background-color: transparent;
}

prompt {
    background-color: transparent;
    text-color:       #ffffff;
    margin:           0 8px 0 0;
}

listview {
    layout:     horizontal;
    spacing:    5px;
    lines:      1;
    background-color: transparent;
}

element {
    background-color: transparent;
}

element selected {
    background-color: transparent;
}

element-text, element-icon {
    background-color: transparent;
    text-color: inherit;
}
