#!/bin/bash
# dunst-typing — typewriter effect for dunst notifications
# Runs as a dunst script rule. Reads notification data from env vars.
# Skips notifications already tagged as "typed" to prevent recursion.

[[ "$DUNST_STACK_TAG" == "typed" ]] && exit 0

SUMMARY="$DUNST_SUMMARY"
BODY="$DUNST_BODY"
TIMEOUT="${DUNST_TIMEOUT:-5000}"
CHAR_DELAY=0.008

# Generate a unique replace ID per notification (based on PID + timestamp)
REPLACE_ID=$(( (RANDOM << 15 | RANDOM) % 2147483647 ))

FULL_TEXT="$SUMMARY"
[[ -n "$BODY" ]] && FULL_TEXT="$SUMMARY  $BODY"

LEN=${#FULL_TEXT}

# Type out character by character, revealing from right to left
for (( i=1; i<=LEN; i++ )); do
    PARTIAL="${FULL_TEXT:LEN-i:i}"
    dunstify -r "$REPLACE_ID" -h "string:x-dunst-stack-tag:typed" -t "$TIMEOUT" "$PARTIAL" "" 2>/dev/null
    sleep "$CHAR_DELAY"
done

# Final notification with proper formatting and real timeout
dunstify -r "$REPLACE_ID" -h "string:x-dunst-stack-tag:typed" -t "$TIMEOUT" "$SUMMARY" "$BODY" 2>/dev/null
